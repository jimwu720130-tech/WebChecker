# ===========================================================
# Streamlit Cloud 持久化設定樣本
# ===========================================================
# 用途：避免 Streamlit Cloud 容器重啟後，常用網站（favorites.json）與
#       排除規則（config.json）回到 git 倉庫的初始狀態。
#
# 啟用步驟：
#   1) 至 https://gist.github.com/ 建立一個「Secret gist」（以你帳號登入）。
#      在 gist 中分別建立兩個檔案，可先填以下空殼：
#        - favorites.json   內容為：[]
#        - config.json      內容為：{}
#      建立後，gist 網址會像  https://gist.github.com/<user>/<gist_id>
#      把 <gist_id> 那段（32 個十六進位字元）抄起來。
#
#   2) 至 https://github.com/settings/tokens?type=beta 建立 Fine-grained
#      Personal Access Token：
#        - Resource owner：你個人或組織
#        - Repository access：可選 "No access"（gist 不需要 repo 權限）
#        - Account permissions：把 "Gists" 設為 "Read and write"
#      建立後立刻把 token 字串複製下來。
#
#   3) 在 Streamlit Cloud 後台 (share.streamlit.io) →
#        該 app 右上「︙」 → "Settings" → "Secrets" 貼上下方內容
#        並把 gist_token / gist_id 換成上面取得的值，按 "Save"，再 "Reboot app"。
#
#   4) 本機若也想測同步行為，把這個檔複製成 .streamlit/secrets.toml
#        （該檔已被 .gitignore 排除，不會被推上 GitHub）。
# ===========================================================

[github]
gist_token = "ghp_REPLACE_ME_WITH_YOUR_PAT"
gist_id    = "REPLACE_ME_WITH_YOUR_GIST_ID"
